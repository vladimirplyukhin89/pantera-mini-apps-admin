{
  "kind": "collectionType",
  "collectionName": "club-values",
  "info": {
    "singularName": "club-value",
    "pluralName": "club-values",
    "displayName": "Club Value"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "accent_color": {
      "type": "enumeration",
      "enum": [
        "red",
        "teal",
        "orange",
        "purple",
        "green"
      ]
    }
  }
}
