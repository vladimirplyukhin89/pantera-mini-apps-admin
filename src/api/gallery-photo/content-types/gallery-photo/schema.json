{
  "kind": "collectionType",
  "collectionName": "gallery-photos",
  "info": {
    "singularName": "gallery-photo",
    "pluralName": "gallery-photos",
    "displayName": "Gallery Photo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "alt": {
      "type": "string"
    },
    "variant": {
      "type": "enumeration",
      "enum": [
        "default",
        "tall",
        "wide"
      ]
    },
    "order": {
      "type": "integer"
    },
    "slug": {
      "type": "uid",
      "targetField": "alt"
    }
  }
}
