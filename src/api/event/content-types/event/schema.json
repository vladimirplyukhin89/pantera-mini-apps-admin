{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "emoji": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "teaser": {
      "type": "text"
    },
    "date_label": {
      "type": "string"
    },
    "body": {
      "type": "blocks"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "accent_index": {
      "type": "integer"
    },
    "order": {
      "type": "integer"
    }
  }
}
