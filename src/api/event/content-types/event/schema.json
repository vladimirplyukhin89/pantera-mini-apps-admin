{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "title": {
      "type": "string"
    },
    "teaser": {
      "type": "text"
    },
    "date_label": {
      "type": "string"
    },
    "statusPlan": {
      "type": "enumeration",
      "default": "past",
      "enum": [
        "planned",
        "past"
      ]
    },
    "body": {
      "type": "blocks"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "video_cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accent_index": {
      "type": "integer"
    },
    "event_at": {
      "type": "datetime"
    },
    "order": {
      "type": "integer"
    }
  }
}
